}

ACTOR Wallsmoke
{
    //Projectile
    Speed 0
    vspeed 0
    -FLOAT
    +NOCLIP
    +NOBLOCKMAP
    -SOLID
    -SHOOTABLE
    +NOGRAVITY
    -Friendly
   Radius 1
   Height 1
    Scale 0.2
    renderstyle add
    Alpha 0.8
	+CLIENTSIDEONLY
    -Randomize
    +NOTARGET
    States
    {
      Spawn:
        P2FF A 0
      Missile:
        P2FF A 0 A_FaceTarget
        P2FF A 0 A_CustomMissile ("Wallsmoke2", 1, 0, random(-8,8), 8, 1) 
        Stop
    }
}

ACTOR Wallsmoke2
{
    Projectile
    +Missile
   Radius 1
   Height 1
    -FLOAT
    Speed 1
    vspeed 0
    YScale 0.6//.3
    XScale 0.34//.17
    renderstyle translucent
    Alpha 0.3//.5
    -Randomize
    +NOTARGET
    +NOCLIP
    +NOBLOCKMAP
    -SOLID
    -SHOOTABLE
    +RIPPER
	+CLIENTSIDEONLY
    States
    {
      Spawn:
        PUF5 ABC 2 Bright ThrustThingZ(0, 1, 0, 0) 
        PUF5 DEFGH 2 ThrustThingZ(0, 1, 0, 0) 
      Spawn2:
        PUF5 IJKK 2 ThrustThingZ(0, 1, 0, 0)
	  Spawn3:
	    PUF5 M 0 A_Jump(120,2)
		PUF5 M 0 A_FadeOut(0.05)
		Goto Spawn2
	  Spawn4:
        PUF5 LLMMMNNN 2 ThrustThingZ(0, 1, 0, 0) 
	  Spawn5:
	    PUF5 M 0 A_Jump(120,2)
		PUF5 M 0 A_FadeOut(0.05)
		Goto Spawn4
        PUF5 OOOPPPP 2 ThrustThingZ(0, 1, 0, 0) 
        Stop
    }
}
