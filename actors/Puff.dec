//should clientside only?
actor SSTBulletPUFF : BulletPUFF replaces BulletPUFF
{
  Game Doom
  SpawnID 131
  //+DONTSPLASH
  +NOBLOCKMAP
  +NOGRAVITY
  -ALLOWPARTICLES
  -RANDOMIZE
  -DONTSPLASH
  RenderStyle translucent
  Alpha 1.0
  VSpeed 1
  Scale 0.85
  Mass 5
  +NOEXTREMEDEATH
  +THRUGHOST
  +puffGetsOwner
  +puffOnActors
  seeSound "weapons/bullethit"
  States
  {
  Spawn:
    PUFF A 0 NoDelay A_Quake(1,4,0,48,0)
    PUFF A 0 A_FaceTarget
    PUFF A 0 A_Jump(127,"spawn3")
    PUFF A 0 A_Jump(127,"Spawn2")
    TNT1 A 0 A_Playsound("weapons/trace",CHAN_WEAPON)
    PUFF A 1 bright
	PUFF A 0 A_CustomMissile("BulletImpactSmoke",0,0,random(-90,90),CMF_AIMDIRECTION,random(0,-90))
	//FRTB A 0 A_SpawnItemEx ("Wallsmoke", 0,0,0, 0,0,0, 0, 160, 64) 
	NULL A 0 A_SpawnItemEx ("PUFFEffectSpawner", 0,0,0, 0,0,0, 0, 160) 
    PUFF B 1 bright A_FadeOut(0.1,0)
    // Intentional fall-through
  Melee:
    PUFF CD 1 bright A_FadeOut(0.1,0)
    goto dead
  Spawn3:
	TNT1 A 0 A_Jump(128,2)
    	TNT1 A 0 A_PlaySound("world/ricochet",CHAN_WEAPON)
	TNT1 A 0 A_CustomMissile("BulletRicochetSmoke",0,0,random(-90,90),CMF_AIMDIRECTION,random(0,-90))
	TNT1 A 0 Bright A_SpawnItemEx("ricochetspawner",0,0,0, 0,0,0, 0, SXF_NOCHECKPOSITION|SXF_CLIENTSIDE)
	goto s2cont
  Spawn2:
    PUF2 A 0 bright
    TNT1 A 0 A_Playsound("weapons/trace",CHAN_WEAPON)
    PUF2 A 1 bright A_FadeOut(0.1,0)
    s2cont: //[sm] ricochets must spawn sparks too!
	PUFF AA 0 A_CustomMissile("BulletImpactSmoke",0,0,random(-67.5,67.5),CMF_AIMDIRECTION,random(0,-67.5))
	//FRTB A 0 A_SpawnItemEx ("Wallsmoke", 0,0,0, 0,0,0, 0, 160, 64) 
	NULL A 0 A_SpawnItemEx ("PUFFEffectSpawner", 0,0,0, 0,0,0, 0, 160) 
    PUF2 ABCD 1 bright A_FadeOut(0.1,0)
    goto dead
   xdeath:
	goto null
   dead:
     TNT1 A 35 //maybe add some smoke here...
     stop

  }
}
actor ricochetspawner
{
+NOCLIP
+NOGRAVITY
states
{
Spawn:
TNT1 A 0
Death:
TNT1 A 0 A_CustomMissile("Ricochet2",0,0,Random(-180,180), 2, Random(-50,50))
Stop
}
}

ACTOR Ricochet2
{
Radius 2
Height 2
Mass 1
Speed 64//34
Damage 0
Health 1
SeeSound ""//"PUFF/ricochet"
PROJECTILE
-noGravity
+bounceautooffflooronly
+DOOMBOUNCE
-DONTSPLASH
+CLIENTSIDEONLY
+NOTELEPORT
+THRUACTORS
+PAINLESS
+BLOODLESSIMPACT
renderstyle add
States
{
Spawn:
    TNT1 A 0 NoDelay A_ScaleVelocity(frandom(0.5,1))
        PUFF A 1 Bright A_FadeOut(0.1)
    TNT1 A 0 A_PlaySound("PUFF/ricochet")
Spawn2:
        PUFF A 1 Bright A_FadeOut(frandom(0,0.1))
        Loop
Death:
        TNT1 A 1
        Stop
        }
} 

//for splodes
actor SilentRicochet2 : Ricochet2
{
	states
	{
		spawn:
		PUFF A 1 Bright A_FadeOut(frandom(0,0.6))
		wait
	}
}

actor SilentRicochetSpawner : RicochetSpawner
{
	states
	{	spawn:
		death:
		TNT1 A 0 NoDelay A_CustomMissile("SilentRicochet2",0,0,random(0,360), CMF_AIMDIRECTION, random(0,90)-random(0,90))
		stop
	}
}

ACTOR PUFFEffectSpawner
{
	+NOTELEPORT
  Radius 1
  Height 1
  +NOBLOCKMAP
  +NOTELEPORT
  +NOGRAVITY
  +NOCLIP
  -SOLID
  -SHOOTABLE
  +DONTSPLASH
  RENDERSTYLE NONE
  States
  {
  Spawn:
    TNT1 A 0
      TNT1 AA 0 Bright A_CustomMissile("PUFFEffect4",0,0,random(-180,180),2,random(-80,80))//60,90
      TNT1 AAAA 0 Bright A_CustomMissile("PUFFEffect3",0,0,random(-180,180),2,random(-80,80))//45,90
      TNT1 AAAA 0 Bright A_CustomMissile("PUFFEffect2",0,0,random(-180,180),2,random(0,90))
      TNT1 AAAA 0 Bright A_CustomMissile("PUFFEffect1",0,0,random(-180,180),2,random(-45,90))
      Stop
  }
}

ACTOR PUFFEffect1
{
	+NOTELEPORT
  Radius 1
  Height 1
  Speed 8//2
  Damage 0
  Projectile
  -RANDOMIZE
  //+NOCLIP
  +DONTSPLASH
  RenderStyle Add
  Alpha 0.85
  scale 0.4
  -NOGRAVITY
  //Gravity 0.5
  +HEXENBOUNCE
  States
  {
  Spawn:
    PUFF A 0
    PUFF A 0 A_Jump(184,1)
	Stop
    PUFF AAABBBCCCDDDDDDDDDDDD 1 bright A_FadeOut(0.05)
    stop
  }
}

ACTOR PUFFEffect2 : PUFFEffect1
{
  Radius 1
  Height 1
  Speed 12//3
  Damage 0
  Projectile
  -RANDOMIZE
  //+NOCLIP
  //BounceType Doom //MEHHHH
  RenderStyle Add
  Alpha 0.85
  scale 0.35
  -NOGRAVITY
  //Gravity 0.5
  States
  {
  Spawn:
    PUFF A 0
    PUFF A 0 A_Jump(184,1)
	Stop
    PUFF AAABBBCCCDDDDDDDDDDDD 1 bright A_FadeOut(0.05)
    stop
  }
}

ACTOR PUFFEffect3 : PUFFEffect1
{
  Radius 1
  Height 1
  Speed 20//5
  Damage 0
  Projectile
  BounceType Hexen
  BounceFactor 1
  -RANDOMIZE
  //+NOCLIP
  RenderStyle Add
  Alpha 0.85
  scale 0.3
  -NOGRAVITY
  //Gravity 0.5
  States
  {
  Spawn:
    PUFF A 0
    PUFF A 0 A_Jump(184,1)
	Stop
    PUFF AAAAAAAAAAAAAAAA 1 bright A_FadeOut(0.05)
    stop
  }
}

ACTOR PUFFEffect4 : PUFFEffect1
{
  Radius 1
  Height 1
  Speed 16//4
  Damage 0
  Projectile
  BounceType Hexen
  BounceFactor 1
  -RANDOMIZE
  //+NOCLIP
  RenderStyle Add
  Alpha 0.85
